---
import { createMarkdownProcessor } from "@astrojs/markdown-remark";
import {
	ArrowRight,
	ChevronRight,
	Clock,
	Newspaper,
	Search,
	User,
} from "@lucide/astro";
import { app } from "@/api/elysia";
import { Image } from "astro:assets";
import type { NewsItem } from "@/data/News";

const response = await app.handle(
	new Request("https://mpkskansaka.vercel.app/api/news"),
);
const result = await response.json();
const rawNewsData: NewsItem[] = result.success ? result.data : [];

// Process markdown excerpts
const processor = await createMarkdownProcessor();
const newsData = await Promise.all(
	rawNewsData.map(async (item) => {
		const { code } = await processor.render(item.excerpt || "");
		return { ...item, excerptHtml: code };
	}),
);

const newsItems = newsData.filter(
	(item) =>
		item.category?.toLowerCase() === "berita" ||
		item.category?.toLowerCase() === "article" ||
		!item.category,
);

const infoItems = newsData.filter(
	(item) =>
		item.category?.toLowerCase() === "info" ||
		item.category?.toLowerCase() === "penting",
);

const recentNews = newsItems.slice(1, 5);
const highlightNews = newsItems[0];

function isNewItem(createdAt: string) {
	if (!createdAt) return false;
	const itemDate = new Date(createdAt);
	const now = new Date();
	const diffInHours = (now.getTime() - itemDate.getTime()) / (1000 * 60 * 60);
	return diffInHours < 24;
}
---

<section class="container mx-auto px-4 sm:px-6 py-8 sm:py-10 md:py-12" id="berita">
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 sm:gap-8 mb-12">
    <!-- Main News Highlight -->
    <div class="lg:col-span-2 flex flex-col">
      {highlightNews ? (
        <div class="rounded-2xl sm:rounded-3xl overflow-hidden border border-gray-200 bg-white shadow-sm h-full flex flex-col">
          <div class="relative aspect-video w-full overflow-hidden">
            {highlightNews.image ? (
              <Image 
                src={new URL(highlightNews.image.startsWith("http") || highlightNews.image.startsWith("/") ? highlightNews.image : `/i/${highlightNews.image}`, Astro.url).toString()} 
                alt={highlightNews.title} 
                width={800}
                height={450}
                format="webp"
                class="object-cover w-full h-full" 
              />
            ) : (
              <div class="w-full h-full bg-linear-to-br from-primary/20 via-primary/10 to-background flex items-center justify-center">
                <Newspaper class="w-12 h-12 text-primary/40" />
              </div>
            )}
            <div class="absolute top-3 left-3 sm:top-4 sm:left-4 bg-primary text-white text-[10px] sm:text-xs font-black px-3 py-1.5 rounded-full no-drag uppercase tracking-widest shadow-lg">
              TERKINI
            </div>
          </div>
          <div class="p-4 sm:p-6 md:p-8 flex flex-col flex-1 items-start">
            <div class="flex items-center text-xs sm:text-sm text-gray-500 mb-3 sm:mb-4 gap-3 sm:gap-4">
              <span class="flex items-center gap-1"><Clock class="w-3.5 h-3.5" /> {highlightNews.date}</span>
              <span class="-ml-2 -mr-2">|</span>
              <span class="flex items-center gap-1"><User class="w-3.5 h-3.5" /> {highlightNews.author}</span>
            </div>
            <h3 class="text-xl sm:text-2xl md:text-3xl font-bold text-gray-900 mb-3 sm:mb-4 leading-tight cursor-pointer line-clamp-2">
              {highlightNews.title}
            </h3>
            <div class="text-sm sm:text-base text-gray-600 mb-4 sm:mb-6 line-clamp-3 prose-excerpt" set:html={highlightNews.excerptHtml}>
            </div>
            <a href={`/blog/${highlightNews.id}`} class="mt-auto inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 bg-primary text-primary-foreground hover:bg-primary/90 h-9 sm:h-10 px-4 sm:px-6 py-2">
              Baca Selengkapnya
              <ArrowRight class="ml-2 w-4 h-4" />
            </a>
          </div>
        </div>
      ) : (
        <div class="flex items-center justify-center h-full min-h-[400px] bg-gray-50 rounded-3xl border border-dashed border-gray-300">
           <p class="text-gray-500 font-medium">Belum ada berita yang tersedia.</p>
        </div>
      )}
    </div>

    <!-- Sidebar -->
    <div class="flex flex-col gap-4 sm:gap-6 pt-8 lg:pt-0">
      <!-- Search -->
      <div class="bg-gray-50 rounded-xl sm:rounded-2xl p-4 sm:p-6 border border-gray-100">
        <h4 class="font-bold text-gray-900 mb-3 sm:mb-4 flex items-center gap-2 text-sm sm:text-base">
          <Search class="w-[18px] h-[18px] text-primary" />
          Cari Berita
        </h4>
        <form action="/blog" method="GET" class="relative">
          <input type="text" name="q" placeholder="Cari artikel..." class="w-full h-10 px-4 rounded-lg border border-gray-200 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary text-sm" />
          <button type="submit" class="absolute right-1 top-1 w-8 h-8 bg-primary rounded text-white flex items-center justify-center hover:bg-primary/90 transition-colors">
            <ChevronRight class="w-3.5 h-3.5" />
          </button>
        </form>
      </div>

      <!-- Important Info -->
      <div class="bg-[#f4f6f9] rounded-xl sm:rounded-2xl overflow-hidden shadow-sm">
        <div class="bg-[#3C4048] px-4 sm:px-6 py-3 border-b border-gray-700">
          <h4 class="font-bold text-white text-sm tracking-wider uppercase">Info Penting</h4>
        </div>
        <div class="p-3 sm:p-4 flex flex-col gap-3 sm:gap-4 max-h-[300px] overflow-y-auto custom-scrollbar">
          {infoItems.map((info) => {
            const isNew = isNewItem(info.createdAt || '');
            return (
              <div class="flex gap-3 items-start group">
                <span class={`${isNew ? 'bg-red-500 shadow-red-500/20' : 'bg-blue-500 shadow-blue-500/20'} text-white text-[9px] font-black px-2 py-1 rounded uppercase whitespace-nowrap shadow-sm tracking-tighter`}>
                  {isNew ? 'NEW' : 'INFO'}
                </span>
                <p class="text-sm mt-0.5 text-black leading-snug font-semibold line-clamp-2">{info.title}</p>
              </div>
            );
          })}
          
          {infoItems.length === 0 && (
            <div class="flex flex-col items-center py-4 text-center">
              <p class="text-xs text-gray-400 italic">Belum ada informasi terbaru saat ini.</p>
            </div>
          )}
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom Section: Latest News Grid (4 Items) -->
  {recentNews.length > 0 && (
  <div class="mt-16">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-xl sm:text-2xl font-bold text-gray-900 tracking-tight flex items-center gap-2">
        Berita Terbaru
      </h2>
      <a href="/blog" class="text-primary font-bold text-sm flex items-center gap-1 hover:underline group">
        Semua Berita 
        <ArrowRight class="w-4 h-4 transition-transform group-hover:translate-x-1" />
      </a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 sm:gap-8">
      {recentNews.map((news) => (
        <div class="group flex flex-col bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden hover:shadow-md transition-shadow">
          <div class="relative aspect-4/3 overflow-hidden">
            {news.image ? (
              <Image 
                src={new URL(news.image.startsWith("http") || news.image.startsWith("/") ? news.image : `/i/${news.image}`, Astro.url).toString()} 
                alt={news.title} 
                width={400}
                height={300}
                format="webp"
                class="object-cover w-full h-full" 
              />
            ) : (
              <div class="w-full h-full bg-linear-to-br from-primary/20 via-primary/10 to-background flex items-center justify-center">
                <Newspaper class="w-8 h-8 text-primary/40" />
              </div>
            )}
            <div class="absolute top-3 left-3 bg-primary text-white text-[10px] font-black px-3 py-1 rounded-full uppercase tracking-widest shadow-md">
              BERITA
            </div>
          </div>
          <div class="p-5 flex flex-col flex-1">
            <div class="flex items-center text-[11px] text-gray-500 mb-2 gap-2">
              <span class="flex items-center gap-1"><Clock class="w-3 h-3" /> {news.date}</span>
            </div>
            <h3 class="text-base font-bold text-gray-900 mb-2 line-clamp-2 leading-tight">
              {news.title}
            </h3>
            <div class="text-xs text-gray-600 line-clamp-3 mb-4 prose-excerpt" set:html={news.excerptHtml}>
            </div>
            <a href={`/blog/${news.id}`} class="mt-auto flex items-center text-xs font-bold text-primary group/link">
              Baca Selengkapnya 
              <ArrowRight class="ml-1 w-3 h-3 transition-transform group-hover/link:translate-x-1" />
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
  )}
</section>

<style>
  .custom-scrollbar::-webkit-scrollbar {
    width: 4px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: transparent;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: #e2e8f0;
    border-radius: 10px;
  }

  .prose-excerpt :global(p) {
    margin: 0;
    display: inline;
  }

  .prose-excerpt :global(img) {
    display: none;
  }

  .prose-excerpt :global(h1),
  .prose-excerpt :global(h2),
  .prose-excerpt :global(h3),
  .prose-excerpt :global(h4),
  .prose-excerpt :global(h5),
  .prose-excerpt :global(h6) {
    font-size: 1em;
    margin: 0;
    display: inline;
    font-weight: bold;
  }
</style>
