---
import { createMarkdownProcessor } from "@astrojs/markdown-remark";
import { ChevronLeft, Clock, Newspaper, User } from "@lucide/astro";
import { Image } from "astro:assets";
import type { NewsItem } from "@/data/News";

interface Props {
	news: NewsItem;
}

const { news } = Astro.props;

// Process markdown content
const processor = await createMarkdownProcessor();
const { code: contentHtml } = await processor.render(news.excerpt);
---

<div class="max-w-4xl mx-auto px-4 sm:px-6 py-12">
    <!-- Header -->
    <div class="mb-8">
        <div class="flex items-center gap-2 text-primary font-bold text-xs uppercase tracking-widest mb-4">
            <span class="bg-primary/10 px-3 py-1 rounded-full">{news.category || 'Berita'}</span>
        </div>
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-black text-gray-900 leading-tight mb-6">
            {news.title}
        </h1>
        <div class="flex flex-wrap items-center gap-4 text-sm text-gray-500 font-medium">
            <span class="flex items-center gap-1.5">
                <Clock class="w-3.5 h-3.5 text-gray-400" /> 
                {news.date}
            </span>
            <span class="-ml-2 -mr-2">|</span>
            <span class="flex items-center gap-1.5">
                <User class="w-3.5 h-3.5 text-gray-400" /> 
                {news.author}
            </span>
        </div>
        <div class="w-full h-px bg-gray-100 mt-6"></div>
    </div>

    <!-- Featured Image -->
    <div class="mb-12">
        {news.image ? (
            <Image 
                src={new URL(news.image.startsWith("http") || news.image.startsWith("/") ? news.image : `/i/${news.image}`, Astro.url).toString()} 
                alt={news.title} 
                width={1200}
                height={675}
                format="webp"
                class="relative aspect-video overflow-hidden rounded-xl shadow-lg mx-auto max-w-full h-auto object-cover border border-gray-100" 
            />
        ) : (
            <div class="relative aspect-video overflow-hidden rounded-xl shadow-lg mx-auto max-w-full h-auto bg-linear-to-br from-primary/20 via-primary/10 to-background flex items-center justify-center border border-gray-100">
                <Newspaper class="w-16 h-16 text-primary/40" />
            </div>
        )}
    </div>

    <!-- Content -->
    <div class="prose-archive max-w-none" set:html={contentHtml}>
    </div>

    <!-- Back Button -->
    <div class="mt-12">
        <a 
            href="/blog" 
            class="inline-flex items-center px-8 py-3 bg-primary text-white rounded-full text-sm font-black uppercase tracking-wider hover:bg-primary/90 transition-all shadow-md hover:shadow-lg"
        >
            <ChevronLeft class="w-4 h-4 mr-2" />
            Kembali ke Berita
        </a>
    </div>
</div>

<style>
    /* Custom Archive Prose Styling */
    .prose-archive {
        font-size: 1rem;
        line-height: 1.8;
        color: #374151;
    }
    
    .prose-archive :global(p) {
        margin-bottom: 1.5rem;
    }
    
    .prose-archive :global(h2), .prose-archive :global(h1) {
        font-size: 1.25rem;
        font-weight: 800;
        margin-top: 2.5rem;
        margin-bottom: 1rem;
        color: #111827;
        text-transform: uppercase;
    }
    
    .prose-archive :global(h3) {
        font-size: 1.1rem;
        font-weight: 700;
        margin-top: 2rem;
        margin-bottom: 0.75rem;
        color: #111827;
    }
    
    .prose-archive :global(ul) {
        margin-bottom: 1.5rem;
        padding-left: 2rem !important;
        list-style-type: disc !important;
        list-style-position: outside !important;
    }

    .prose-archive :global(ol) {
        margin-bottom: 1.5rem;
        padding-left: 2rem !important;
        list-style-type: decimal !important;
        list-style-position: outside !important;
    }

    .prose-archive :global(ul ul), 
    .prose-archive :global(ol ol),
    .prose-archive :global(ul ol),
    .prose-archive :global(ol ul) {
        margin-top: 0.5rem;
        margin-bottom: 0;
        padding-left: 1.5rem !important;
    }
    
    .prose-archive :global(li) {
        margin-bottom: 0.5rem;
        display: list-item !important;
    }
    
    .prose-archive :global(strong) {
        font-weight: 800;
        color: #111827;
    }
    
    .prose-archive :global(a) {
        color: var(--color-primary);
    }

    .prose-archive :global(blockquote) {
        border-left: 4px solid var(--color-primary);
        padding-left: 1.5rem;
        font-style: italic;
        margin: 2rem 0;
        color: #4B5563;
    }
</style>
