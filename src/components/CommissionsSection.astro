---
import { UserCheck } from "@lucide/astro";
import { commissions } from "../data/Commission";
---

<section class="w-full bg-black overflow-hidden" id="komisi">
  <!-- Section Title -->
  <div class="bg-white py-20 px-8 md:px-24">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-8">
      <div>
        <h2 class="text-4xl md:text-7xl font-black text-gray-900 leading-none tracking-tighter uppercase">
          KOMISI<br/>
          <span class="text-primary">MPK </span>
        </h2>
      </div>
      <div class="max-w-md">
        <p class="text-gray-500 text-lg pb-6 font-medium leading-relaxed">
          Dibawah naungan MPK, terdapat 4 Komisi yang menjadi ujung tombak roda organisasi yang berdedikasi tinggi.
        </p>
      </div>
    </div>
  </div>

  <!-- Full Image Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2">
    {commissions.map((komisi) => (
      <div class="relative aspect-3/4 group overflow-hidden bg-gray-900">
        {/* Main Images */}
        <img 
          src={komisi.image} 
          alt={komisi.subtitle} 
          class="komisi-img absolute inset-0 w-full h-full border-l-2 border-r-2 border-b-2 border-black/10 object-cover group-hover:scale-105 transition-transform duration-300 scale-[1.02]"
        />
        
        {/* Overlays */}
        <div class="absolute inset-0 bg-linear-to-t from-black via-black/40 to-transparent opacity-80 z-10 transition-opacity duration-200"></div>
        <div class={`komisi-color-overlay absolute inset-0 bg-linear-to-br ${komisi.color} to-transparent opacity-0 group-hover:opacity-40 z-20 transition-opacity duration-200`}></div>

        {/* Content */}
        <div class="absolute inset-0 p-8 md:p-16 flex flex-col justify-end">
          {/* Main Text */}
          <div class="komisi-content relative z-10 transition-transform duration-500 group-hover:-translate-y-1">
            <span class="text-primary font-black tracking-widest text-sm uppercase block mb-4">{komisi.title}</span>
            <h3 class="text-3xl md:text-6xl font-black text-white mb-2 uppercase leading-none tracking-tighter">
              {komisi.subtitle}
            </h3>
            <p class="text-primary font-bold text-lg mb-6 uppercase tracking-wider">{komisi.fullName}</p>
            
            <p class="komisi-desc text-white/60 text-lg max-w-md mb-8 leading-relaxed italic group-hover:text-white transition-colors duration-300">
              "{komisi.description}"
            </p>

            {/* Expanded Details */}
            <div class="komisi-details max-h-0 group-hover:max-h-[400px] opacity-0 group-hover:opacity-100 overflow-hidden transition-all duration-700 ease-in-out">
              <div class="pt-8 border-t border-white/20">
                {/* Coordinator */}
                <div class="flex items-center gap-4 mb-8">
                  <div>
                    <span class="text-[10px] text-primary font-black uppercase tracking-[0.3em] block mb-1">Koordinator Komisi</span>
                    <h4 class="text-xl font-bold text-white">{komisi.coordinator.name}</h4>
                    <p class="text-white/50 text-sm">{komisi.coordinator.class}</p>
                  </div>
                </div>

                {/* Members */}
                <div>
                  <span class="text-[10px] text-white/40 font-black uppercase tracking-[0.3em] block mb-4">Anggota Komisi</span>
                  <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-2">
                    {komisi.members.map((member) => (
                      <div class="flex items-center gap-3">
                        <div class="w-1.5 h-1.5 rounded-full bg-primary/60"></div>
                        <span class="text-sm text-white/70 font-medium">{member}</span>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        {/* Number */}
        <span class="komisi-number absolute -bottom-1 -right-10 text-[200px] md:text-[300px] font-black text-white/10 leading-none select-none group-hover:text-white/20 transition-all duration-500">
          {komisi.id}
        </span>
      </div>
    ))}
  </div>
</section>

<style>
  /* Mobile touch-active */
  .group.is-active .komisi-img {
    transform: scale(1.05);
  }
  .group.is-active .komisi-color-overlay {
    opacity: 0.4;
  }
  .group.is-active .komisi-content {
    transform: translateY(-0.25rem);
  }
  .group.is-active .komisi-desc {
    color: white;
  }
  .group.is-active .komisi-details {
    max-height: 400px;
    opacity: 1;
  }
  .group.is-active .komisi-number {
    color: rgba(255,255,255,0.2);
  }
</style>

<script>
  function initKomisiTouch() {
    const cards = document.querySelectorAll('#komisi .group');
    
    cards.forEach((card) => {
      card.addEventListener('click', (e) => {
        const isMobile = window.matchMedia('(max-width: 768px)').matches || 'ontouchstart' in window;
        if (!isMobile) return;
        
        e.preventDefault();
        e.stopPropagation();
        
        const wasActive = card.classList.contains('is-active');
        
        cards.forEach(c => c.classList.remove('is-active'));
        
        if (!wasActive) {
          card.classList.add('is-active');
        }
      });
    });

    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (!target.closest('#komisi .group')) {
        cards.forEach(c => c.classList.remove('is-active'));
      }
    });
  }

  document.addEventListener('astro:page-load', initKomisiTouch);
  initKomisiTouch();
</script>
