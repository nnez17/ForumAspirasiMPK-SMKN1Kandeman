---
import { CircleCheck, Clock, TriangleAlert } from "@lucide/astro";
---

<section class="container mx-auto px-4 py-12">
  <div class="flex items-center justify-between mb-8">
    <h2 class="text-2xl font-bold text-gray-900 tracking-tight">Live Monitoring Aspirasi</h2>
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-50 text-primary text-xs font-semibold">
      <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
      Status Terhubung Real-Time
    </div>
  </div>

  <!-- Total Aspirasi -->
  <div class="p-6 pb-8 flex flex-col items-center justify-center text-center">
    <span class="text-sm font-medium text-gray-500 mb-2">Total Aspirasi Masuk</span>
    <span class="text-5xl font-extrabold text-primary border-b-4 border-primary pb-2">0</span>
  </div>

  <!-- Darurat, Sedang, Info -->
  <div class="grid grid-cols-1 md:grid-cols-3 w-full gap-6">
    <!-- Card 1 -->
    <div class="bg-red-50/50 rounded-2xl p-6 border border-red-100 flex flex-col items-center justify-center text-center">
      <Clock class="text-red-500 mb-2 w-6 h-6" />
      <span class="text-xs font-bold text-red-500 uppercase tracking-wider mb-1">Darurat</span>
      <span class="text-4xl font-extrabold text-red-600">0</span>
    </div>

    <!-- Card 2 -->
    <div class="bg-yellow-50/50 rounded-2xl p-6 border border-yellow-200 flex flex-col items-center justify-center text-center">
      <TriangleAlert class="text-yellow-600 mb-2 w-6 h-6" />
      <span class="text-xs font-bold text-yellow-600 uppercase tracking-wider mb-1">Sedang</span>
      <span class="text-4xl font-extrabold text-yellow-700">0</span>
    </div>

    <!-- Card 3 -->
    <div class="bg-blue-50/50 rounded-2xl p-6 border border-blue-200 flex flex-col items-center justify-center text-center">
      <CircleCheck class="text-blue-500 mb-2 w-6 h-6" />
      <span class="text-xs font-bold text-blue-600 uppercase tracking-wider mb-1">Info</span>
      <span class="text-4xl font-extrabold text-primary">0</span>
    </div>
  </div>
</section>
