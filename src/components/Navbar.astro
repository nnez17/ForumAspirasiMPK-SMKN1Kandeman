---
import MobileMenu from "./MobileMenu.svelte";
---

<header class="sticky top-0 z-100 w-full shadow-md border-b border-white/10 backdrop-blur-xl">
  <div class="container mx-auto px-4 h-16 flex items-center">
    <!-- Mobile Menu Trigger -->
    <div class="mobile-trigger items-center mr-2">
      <MobileMenu client:load />
    </div>

    <!-- Name-->
    <div class="flex items-center flex-1 md:flex-none">
      <a href="#home">
        <h1 class="font-extrabold text-lg sm:text-xl text-primary hover:underline cursor-pointer tracking-tight">
          MPK SMKN 1 KANDEMAN
        </h1>
      </a>
    </div>

    <!-- Desktop Nav -->
    <nav class="desktop-nav items-center h-full gap-1 ml-auto">
      <a href="#home" class="nav-link relative h-full flex items-center px-4 text-sm font-bold text-primary transition-all hover:text-primary shrink-0 whitespace-nowrap group">
        <span class="relative py-1">
          Beranda
          <div class="nav-border absolute -bottom-1 left-0 w-full h-0.5 bg-primary rounded-full transition-all"></div>
        </span>
      </a>
      <a href="#berita" class="nav-link relative h-full flex items-center px-4 text-sm font-bold text-muted-foreground transition-all hover:text-primary shrink-0 whitespace-nowrap group">
        <span class="relative py-1">
          Berita
          <div class="nav-border absolute -bottom-1 left-0 w-full h-0 bg-primary rounded-full transition-all"></div>
        </span>
      </a>
      <a href="#pengurus" class="nav-link relative h-full flex items-center px-4 text-sm font-bold text-muted-foreground transition-all hover:text-primary shrink-0 whitespace-nowrap group">
        <span class="relative py-1">
          Pengurus
          <div class="nav-border absolute -bottom-1 left-0 w-full h-0 bg-primary rounded-full transition-all"></div>
        </span>
      </a>
      <a href="#kontak" class="nav-link relative h-full flex items-center px-4 text-sm font-bold text-muted-foreground transition-all hover:text-primary shrink-0 whitespace-nowrap group">
        <span class="relative py-1">
          Kontak
          <div class="nav-border absolute -bottom-1 left-0 w-full h-0 bg-primary rounded-full transition-all"></div>
        </span>
      </a>
      <a href="/admin" class="nav-link relative h-full flex items-center px-4 text-sm font-bold text-muted-foreground transition-all hover:text-primary shrink-0 whitespace-nowrap group">
        <span class="relative py-1">
          Admin
          <div class="nav-border absolute -bottom-1 left-0 w-full h-0 bg-primary rounded-full transition-all"></div>
        </span>
      </a>
    </nav>
  </div>
</header>

<style>
  .desktop-nav {
    display: none;
  }

  .mobile-trigger {
    display: flex;
    justify-content: flex-start;
  }

  @media (min-width: 768px) {
    .desktop-nav {
      display: flex;
    }
    .mobile-trigger {
      display: none;
    }
  }
</style>

<script>
  function initNav() {
    const navLinks = document.querySelectorAll('.nav-link');
    
    function updateActiveState() {
      const currentHash = window.location.hash;
      const currentPath = window.location.pathname;

      navLinks.forEach(link => {
        const border = link.querySelector('div');
        const href = link.getAttribute('href');
        if (!href) return;

        const isHashLink = href.startsWith('#');
        let isActive = false;

        if (isHashLink) {
          const activeHash = currentHash || '#home';
          isActive = href === activeHash;
        } else {
          isActive = currentPath === href || currentPath === href + '/';
        }

        if (isActive) {
          link.classList.add('text-primary');
          link.classList.remove('text-muted-foreground');
          if (border) border.classList.replace('h-0', 'h-0.5');
        } else {
          link.classList.remove('text-primary');
          link.classList.add('text-muted-foreground');
          if (border) border.classList.replace('h-0.5', 'h-0');
        }
      });
    }

    updateActiveState();

    navLinks.forEach(link => {
      link.addEventListener('click', (e) => {
        const href = link.getAttribute('href');
        if (href?.startsWith('#')) {
          setTimeout(updateActiveState, 0);
        }
      });
    });

    window.addEventListener('hashchange', updateActiveState);
  }

  initNav();
  document.addEventListener('astro:after-swap', initNav);
</script>