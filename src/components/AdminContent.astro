---
import {
	Plus,
	Trash2,
	Edit,
	Save,
	LogOut,
	LayoutDashboard,
	MessageSquare,
	Newspaper,
	ShieldCheck,
	ChevronRight,
	Bell,
} from "@lucide/astro";

const aspirations = [
	{
		id: 1,
		name: "Budi Santoso",
		class: "XII RPL 1",
		subject: "Fasilitas Kantin",
		message:
			"Mohon diperbaiki meja kantin yang rusak agar lebih nyaman saat istirahat.",
		status: "Pending",
	},
	{
		id: 2,
		name: "Ani Wijaya",
		class: "XI TKJ 2",
		subject: "Jadwal Ekstrakurikuler",
		message: "Apakah bisa ditambahkan ekskul robotik di semester depan?",
		status: "Diterima",
	},
	{
		id: 3,
		name: "Siti Aminah",
		class: "X DKV 3",
		subject: "Lomba Sekolah",
		message: "Kapan ada lomba desain poster lagi untuk tingkat kabupaten?",
		status: "Selesai",
	},
	{
		id: 4,
		name: "Rizky Pratama",
		class: "XII TKR 1",
		subject: "Parkir Motor",
		message: "Area parkir motor kelas XII mohon diperluas sedikit lagi.",
		status: "Pending",
	},
];

const adminPassword = import.meta.env.ADMIN_PASSWORD || "admin123";
---

    <main class="min-h-screen bg-[#F8FAFC] pt-28 pb-12">
        <div class="container mx-auto px-4">
            <!-- Admin Welcome Header -->
            <div class="flex flex-col md:flex-row md:items-center justify-between mb-10 gap-6">
                <div class="space-y-1">
                    <div class="flex items-center gap-2 text-primary font-bold text-sm uppercase tracking-wider">
                        <ShieldCheck class="w-4 h-4" />
                        Administrator Access
                    </div>
                    <h1 class="text-4xl font-black text-gray-900 tracking-tight">
                        Admin <span class="text-primary">Dashboard</span>
                    </h1>
                    <p class="text-gray-500 font-medium">Selamat datang kembali! Kelola informasi dan aspirasi dalam satu panel.</p>
                </div>
                
                <!-- Security Info Badge -->
                <div class="bg-white p-4 rounded-2xl shadow-sm border border-gray-100 flex items-center gap-4 group hover:border-primary/30 transition-all duration-300">
                    <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center text-primary group-hover:scale-110 transition-transform">
                        <ShieldCheck class="w-6 h-6" />
                    </div>
                    <div>
                        <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Master Password</p>
                        <p class="text-lg font-black text-primary tracking-widest">{adminPassword}</p>
                    </div>
                    <div class="ml-4 pl-4 border-l border-gray-100">
                        <div class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></div>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
                <!-- Left Sidebar Nav -->
                <div class="lg:col-span-3">
                    <div class="bg-white rounded-3xl shadow-xl shadow-gray-200/50 border border-gray-100 p-4 sticky top-28 overflow-hidden">
                        <!-- Navigation Profile (Small) -->
                        <div class="p-4 mb-4 bg-gray-50 rounded-2xl flex items-center gap-3">
                            <div class="w-10 h-10 rounded-full bg-primary flex items-center justify-center text-white font-bold">A</div>
                            <div>
                                <p class="text-sm font-bold text-gray-900 leading-tight">Admin MPK</p>
                                <p class="text-[10px] text-gray-500 font-medium">Super User</p>
                            </div>
                        </div>

                        <nav class="space-y-1">
                            <a href="#dashboard" class="flex items-center justify-between px-4 py-3 rounded-xl bg-primary/5 text-primary font-bold group transition-all">
                                <span class="flex items-center gap-3">
                                    <LayoutDashboard class="w-5 h-5" />
                                    Dashboard
                                </span>
                                <ChevronRight class="w-4 h-4 opacity-0 group-hover:opacity-100 transition-opacity" />
                            </a>
                            <a href="#berita" class="flex items-center justify-between px-4 py-3 rounded-xl text-gray-600 hover:bg-gray-50 font-semibold group transition-all">
                                <span class="flex items-center gap-3">
                                    <Newspaper class="w-5 h-5" />
                                    Berita & Info
                                </span>
                                <ChevronRight class="w-4 h-4 opacity-0 group-hover:opacity-100 transition-opacity" />
                            </a>
                            <a href="#aspirasi" class="flex items-center justify-between px-4 py-3 rounded-xl text-gray-600 hover:bg-gray-50 font-semibold group transition-all">
                                <span class="flex items-center gap-3">
                                    <MessageSquare class="w-5 h-5" />
                                    Aspirasi Siswa
                                </span>
                                <span class="bg-red-500 text-white text-[10px] px-2 py-0.5 rounded-full">4</span>
                            </a>
                        </nav>
                        
                        <div class="mt-8 pt-6 border-t border-gray-100 px-2">
                             <button class="w-full flex items-center gap-3 px-4 py-3 rounded-xl text-red-500 hover:bg-red-50 font-bold transition-all group">
                                <LogOut class="w-5 h-5 group-hover:-translate-x-1 transition-transform" />
                                Logout
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Main Dashboard Area -->
                <div class="lg:col-span-9 space-y-8">
                    
                    <!-- Stats Quick View -->
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                        <div class="bg-white p-6 rounded-3xl shadow-sm border border-gray-100 relative overflow-hidden group">
                            <div class="absolute -right-4 -bottom-4 w-24 h-24 bg-blue-500/5 rounded-full group-hover:scale-150 transition-transform duration-500"></div>
                            <div class="flex items-center gap-4 mb-4">
                                <div class="w-12 h-12 rounded-2xl bg-blue-50 text-blue-600 flex items-center justify-center">
                                    <Newspaper class="w-6 h-6" />
                                </div>
                                <span class="text-sm font-bold text-gray-400 uppercase tracking-widest">Articles</span>
                            </div>
                            <h3 class="text-3xl font-black text-gray-900">12 <span class="text-sm font-medium text-gray-400 font-sans tracking-normal ml-2">Dipublish</span></h3>
                        </div>

                        <div class="bg-white p-6 rounded-3xl shadow-sm border border-gray-100 relative overflow-hidden group">
                            <div class="absolute -right-4 -bottom-4 w-24 h-24 bg-amber-500/5 rounded-full group-hover:scale-150 transition-transform duration-500"></div>
                            <div class="flex items-center gap-4 mb-4">
                                <div class="w-12 h-12 rounded-2xl bg-amber-50 text-amber-600 flex items-center justify-center">
                                    <MessageSquare class="w-6 h-6" />
                                </div>
                                <span class="text-sm font-bold text-gray-400 uppercase tracking-widest">Aspiration</span>
                            </div>
                            <h3 class="text-3xl font-black text-gray-900">42 <span class="text-sm font-medium text-gray-400 font-sans tracking-normal ml-2">Total</span></h3>
                        </div>

                        <div class="bg-white p-6 rounded-3xl shadow-sm border border-gray-100 relative overflow-hidden group">
                            <div class="absolute -right-4 -bottom-4 w-24 h-24 bg-purple-500/5 rounded-full group-hover:scale-150 transition-transform duration-500"></div>
                            <div class="flex items-center gap-4 mb-4">
                                <div class="w-12 h-12 rounded-2xl bg-purple-50 text-purple-600 flex items-center justify-center">
                                    <Bell class="w-6 h-6" />
                                </div>
                                <span class="text-sm font-bold text-gray-400 uppercase tracking-widest">Updates</span>
                            </div>
                            <h3 class="text-3xl font-black text-gray-900">3 <span class="text-sm font-medium text-gray-400 font-sans tracking-normal ml-2">Notifikasi</span></h3>
                        </div>
                    </div>

                    <!-- Form: Tambah Berita & Info -->
                    <section id="berita" class="bg-white rounded-3xl shadow-xl shadow-gray-200/40 border border-gray-100 overflow-hidden transform transition-all duration-300">
                        <div class="p-8 border-b border-gray-50 flex items-center justify-between bg-linear-to-r from-white to-gray-50">
                            <div>
                                <h2 class="text-2xl font-black text-gray-900 tracking-tight flex items-center gap-3">
                                    <Plus class="w-6 h-6 text-primary" />
                                    Publish Content
                                </h2>
                                <p class="text-gray-500 text-sm font-medium mt-1">Buat berita atau info baru untuk muncul di halaman utama.</p>
                            </div>
                        </div>
                        <div class="p-8">
                            <form class="grid grid-cols-1 md:grid-cols-2 gap-8">
                                <div class="space-y-3">
                                    <label class="text-xs font-bold text-gray-400 uppercase tracking-widest">Judul Artikel</label>
                                    <input type="text" placeholder="Contoh: Rapat Pleno MPK SMKN 1 Kandeman" class="w-full px-5 py-3 rounded-2xl bg-gray-50 border border-transparent focus:bg-white focus:border-primary/30 focus:ring-4 focus:ring-primary/5 outline-none transition-all font-medium text-gray-900 placeholder:text-gray-300" />
                                </div>
                                <div class="space-y-3">
                                    <label class="text-xs font-bold text-gray-400 uppercase tracking-widest">Kategori Konten</label>
                                    <div class="relative">
                                        <select class="w-full px-5 py-3 rounded-2xl bg-gray-50 border border-transparent focus:bg-white focus:border-primary/30 focus:ring-4 focus:ring-primary/5 outline-none transition-all font-bold text-gray-700 appearance-none">
                                            <option>BERITA</option>
                                            <option>INFO PENTING</option>
                                        </select>
                                        <ChevronRight class="absolute right-5 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400 rotate-90" />
                                    </div>
                                </div>
                                <div class="space-y-3 md:col-span-2">
                                    <label class="text-xs font-bold text-gray-400 uppercase tracking-widest">Ringkasan Berita</label>
                                    <textarea rows="4" placeholder="Tuliskan deskripsi singkat atau ringkasan berita disini..." class="w-full px-5 py-3 rounded-2xl bg-gray-50 border border-transparent focus:bg-white focus:border-primary/30 focus:ring-4 focus:ring-primary/5 outline-none transition-all font-medium text-gray-900 placeholder:text-gray-300"></textarea>
                                </div>
                                <div class="space-y-3">
                                    <label class="text-xs font-bold text-gray-400 uppercase tracking-widest">URL Gambar (Opsional)</label>
                                    <input type="text" placeholder="https://..." class="w-full px-5 py-3 rounded-2xl bg-gray-50 border border-transparent focus:bg-white focus:border-primary/30 focus:ring-4 focus:ring-primary/5 outline-none transition-all font-medium text-gray-900" />
                                </div>
                                <div class="space-y-3">
                                    <label class="text-xs font-bold text-gray-400 uppercase tracking-widest">Nama Penulis</label>
                                    <input type="text" placeholder="Admin MPK" class="w-full px-5 py-3 rounded-2xl bg-gray-50 border border-transparent focus:bg-white focus:border-primary/30 focus:ring-4 focus:ring-primary/5 outline-none transition-all font-medium text-gray-900" />
                                </div>
                                <div class="md:col-span-2 flex flex-col sm:flex-row justify-end gap-4 pt-4">
                                    <button type="reset" class="px-8 py-3 rounded-2xl border border-gray-200 text-gray-500 font-bold hover:bg-gray-50 hover:text-gray-900 transition-all">Clear Form</button>
                                    <button type="submit" class="px-8 py-3 rounded-2xl bg-primary text-white font-bold shadow-lg shadow-primary/30 hover:bg-primary/90 hover:scale-105 active:scale-95 transition-all flex items-center justify-center gap-3">
                                        <Save class="w-5 h-5" />
                                        Publish Now
                                    </button>
                                </div>
                            </form>
                        </div>
                    </section>

                    <!-- Table: Aspirasi Siswa -->
                    <section id="aspirasi" class="bg-white rounded-3xl shadow-xl shadow-gray-200/40 border border-gray-100 overflow-hidden transform transition-all duration-300">
                        <div class="p-8 border-b border-gray-50 flex items-center justify-between">
                            <div>
                                <h2 class="text-2xl font-black text-gray-900 tracking-tight flex items-center gap-3">
                                    <MessageSquare class="w-6 h-6 text-primary" />
                                    Student Voice
                                </h2>
                                <p class="text-gray-500 text-sm font-medium mt-1">Daftar aspirasi masuk dari siswa SMKN 1 Kandeman.</p>
                            </div>
                        </div>
                        <div class="overflow-x-auto">
                            <table class="w-full text-left">
                                <thead class="bg-gray-50/50 border-b border-gray-100">
                                    <tr>
                                        <th class="px-8 py-5 text-[10px] font-black text-gray-400 uppercase tracking-[0.2em]">Siswa</th>
                                        <th class="px-8 py-5 text-[10px] font-black text-gray-400 uppercase tracking-[0.2em]">Perihal</th>
                                        <th class="px-8 py-5 text-[10px] font-black text-gray-400 uppercase tracking-[0.2em]">Pesan</th>
                                        <th class="px-8 py-5 text-[10px] font-black text-gray-400 uppercase tracking-[0.2em]">Status</th>
                                        <th class="px-8 py-5 text-[10px] font-black text-gray-400 uppercase tracking-[0.2em]">Action</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-gray-50">
                                    {aspirations.map((item) => (
                                        <tr class="hover:bg-gray-50/30 transition-colors group">
                                            <td class="px-8 py-6">
                                                <div class="font-bold text-gray-900 group-hover:text-primary transition-colors">{item.name}</div>
                                                <div class="text-[10px] text-gray-400 font-bold uppercase tracking-wider">{item.class}</div>
                                            </td>
                                            <td class="px-8 py-6 text-sm text-gray-700 font-bold">{item.subject}</td>
                                            <td class="px-8 py-6 text-sm text-gray-500 max-w-[240px] leading-relaxed">
                                                <p class="line-clamp-2">{item.message}</p>
                                            </td>
                                            <td class="px-8 py-6">
                                                <span class={`inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest ${
                                                    item.status === 'Pending' ? 'bg-amber-100 text-amber-600' : 
                                                    item.status === 'Diterima' ? 'bg-blue-100 text-blue-600' : 'bg-green-100 text-green-600'
                                                }`}>
                                                    <span class="w-1.5 h-1.5 rounded-full bg-current"></span>
                                                    {item.status}
                                                </span>
                                            </td>
                                            <td class="px-8 py-6">
                                                <div class="flex items-center gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                                    <button class="w-9 h-9 rounded-xl bg-blue-50 text-blue-600 flex items-center justify-center hover:bg-blue-600 hover:text-white transition-all shadow-sm" title="Review">
                                                        <Edit class="w-4 h-4" />
                                                    </button>
                                                    <button class="w-9 h-9 rounded-xl bg-red-50 text-red-500 flex items-center justify-center hover:bg-red-500 hover:text-white transition-all shadow-sm" title="Delete">
                                                        <Trash2 class="w-4 h-4" />
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    ))}
                                </tbody>
                            </table>
                        </div>
                        <div class="p-6 bg-gray-50/50 border-t border-gray-100 flex justify-center">
                            <button class="text-xs font-black text-primary hover:tracking-widest uppercase transition-all flex items-center gap-2 group">
                                View Archive
                                <ChevronRight class="w-4 h-4 group-hover:translate-x-1 transition-transform" />
                            </button>
                        </div>
                    </section>

                </div>
            </div>
        </div>
    </main>
    
<style>
    /* Premium scroll behavior */
    html {
        scroll-padding-top: 100px;
    }
    
    ::-webkit-scrollbar {
        width: 10px;
    }
    ::-webkit-scrollbar-track {
        background: #F8FAFC;
    }
    ::-webkit-scrollbar-thumb {
        background: #E2E8F0;
        border-radius: 20px;
        border: 3px solid #F8FAFC;
    }
    ::-webkit-scrollbar-thumb:hover {
        background: #CBD5E1;
    }

    /* Hide scrollbar for forms/tables if needed */
    .no-scrollbar::-webkit-scrollbar {
        display: none;
    }
</style>
