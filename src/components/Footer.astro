---
import { Camera, Globe, Mail, Music2 } from "@lucide/astro";
---

<footer class="bg-[#1f2937] text-gray-300 py-16 border-t border-gray-800">
  <div class="container mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12 mb-12">
      <!-- Col 1: About -->
      <div class="flex flex-col gap-6">
        <div class="flex items-center gap-3">
          <span class="font-bold text-white tracking-tight">MPK SMKN 1 KANDEMAN</span>
        </div>
        <p class="text-sm text-gray-400 leading-relaxed">
          MPK SMK Negeri 1 Kandeman adalah wadah aspirasi dan kreativitas bagi seluruh siswa SMK Negeri 1 Kandeman. Kami hadir untuk mewujudkan iklim pendidikan yang progresif, inklusif, dan transparan.
        </p>
      </div>

      <!-- Col 2: Menu -->
      <div>
        <h4 class="text-white font-bold tracking-wider text-sm uppercase mb-6">Menu</h4>
        <ul class="space-y-4">
          <li><a href="#" class="text-sm text-gray-400 hover:text-primary transition-colors">Tentang Kami</a></li>
          <li><a href="#" class="text-sm text-gray-400 hover:text-primary transition-colors">Program Kerja</a></li>
          <li><a href="#" class="text-sm text-gray-400 hover:text-primary transition-colors">Ruang Aspirasi</a></li>
          <li><a href="#" class="text-sm text-gray-400 hover:text-primary transition-colors">Dokumentasi</a></li>
        </ul>
      </div>

      <!-- Col 3: Kontak -->
      <div>
        <h4 class="text-white font-bold tracking-wider text-sm uppercase mb-6">Kontak</h4>
        <ul class="space-y-4 mb-6">
          <li>
            <a href="mailto:info@mpkskandeman.org" class="text-sm text-gray-400 hover:text-primary transition-colors flex items-center gap-3">
              <Mail class="w-4 h-4" />
              info@mpkskandeman.org
            </a>
          </li>
          <li>
            <a href="" class="text-sm text-gray-400 hover:text-primary transition-colors flex items-center gap-3">
              <Globe class="w-4 h-4" />
              mpkskandeman.or.id
            </a>
          </li>
        </ul>
        <div class="flex items-center gap-4">
          <a href="https://www.instagram.com/mpk.skansaka/" class="w-10 h-10 rounded-full bg-gray-800 flex items-center justify-center transition-all">
            <img src="/images/instagram.webp" alt="Instagram" class="w-8 h-8" />
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom -->
    <div class="pt-8 border-t border-gray-800 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-xs text-gray-500">
        &copy; 2026 MPK SMK N 1 KANDEMAN. ALL RIGHTS RESERVED.
      </p>
      <div class="flex items-center gap-6">
        <a href="#" class="text-xs text-gray-500 hover:text-white transition-colors">PRIVACY POLICY</a>
        <a href="#" class="text-xs text-gray-500 hover:text-white transition-colors">TERMS OF SERVICE</a>
      </div>
    </div>
  </div>
</footer>
