---
import { SendHorizontal } from "@lucide/astro";
import { Button } from "@/components/ui/button";
---
<section class="relative w-full overflow-hidden">
  <!-- Decorative Top  -->
  <div class="absolute top-0 left-0 w-full h-8 bg-linear-to-r from-sky-700 via-sky-800 to-sky-700 z-40 shadow-xl flex items-center px-8 md:px-24 border-b-4 border-[#fbbf24]">
  </div>

  <div 
    class="relative w-full h-[80vh] md:h-[90vh] flex items-center bg-cover bg-center"
    style="background-image: url('/images/hero.webp');"
  >
    <!-- Overlay -->
    <div class="absolute inset-0 bg-sky-900/40 mix-blend-multiply"></div>
    <div class="absolute inset-0 bg-linear-to-r from-sky-900/80 via-sky-600/30 to-transparent"></div>

    <!-- Hanging Logos -->
    <div class="absolute top-8 left-8 md:left-24 flex gap-6 z-50">
      <!-- MPK Logo -->
      <div class="relative group">
        <div class="w-16 h-24 md:w-28 md:h-40 bg-white flex flex-col items-center justify-center p-2 md:p-4 relative shadow-2xl" style="clip-path: polygon(0 0, 100% 0, 100% 85%, 50% 100%, 0 85%);">
          <img src="/images/logo-mpk.webp" alt="Logo MPK" class="w-full h-auto object-contain" />
        </div>
      </div>
      
      <!-- SMK Logo -->
      <div class="relative group">
        <div class="w-16 h-24 md:w-28 md:h-40 bg-white flex flex-col items-center justify-center p-2 md:p-4 relative shadow-2xl" style="clip-path: polygon(0 0, 100% 0, 100% 85%, 50% 100%, 0 85%);">
          <img src="/images/logo-smk.webp" alt="Logo SMK" class="w-full h-auto object-contain" />
        </div>
      </div>
    </div>

    <!-- Main Content -->
    <div class="relative z-10 w-full px-8 md:px-24 mt-20">
      <div class="max-w-4xl">
        <h1 class="text-4xl md:text-8xl font-black text-white leading-[0.9] mb-8 tracking-tighter uppercase" style="text-shadow: 4px 4px 15px rgba(0,0,0,0.3);">
          LAYANAN<br/>
          <span class="text-[#fbbf24]">ASPIRASI</span> SISWA
        </h1>
        
        <p class="text-xl md:text-2xl text-white/90 max-w-2xl mb-12 leading-relaxed font-medium border-l-4 border-[#fbbf24] pl-6">
          Sampaikan aspirasi, kritik, dan saran untuk kemajuan SMK N 1 Kandeman yang lebih transparan dan inovatif. Suaramu adalah prioritas kami.
        </p>
        
        <div class="flex flex-wrap items-center gap-6">
          <Button variant="secondary" class="h-12 px-10 text-base font-bold shadow-lg bg-[#ffcc00] text-[#8b0000] hover:bg-[#e6b800]">
            Sampaikan Aspirasi
            <SendHorizontal class="w-5 h-5 ml-2" />
          </Button>
          <Button variant="outline" class="h-12 px-10 text-base border-2 border-white/30 bg-white/10 text-white hover:bg-white/20 hover:text-white backdrop-blur-md font-bold shadow-lg">
            Selengkapnya
          </Button>
        </div>
      </div>
    </div>
  </div>
</section>
