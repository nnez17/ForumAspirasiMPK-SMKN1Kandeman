---
import { SendHorizontal } from "@lucide/astro";
import { Button } from "@/components/ui/button";
---
<section class="relative w-full overflow-hidden" id="home">
  <!-- Decorative Top  -->
  <div class="absolute top-0 left-0 w-full h-8 bg-linear-to-r from-sky-700 via-sky-800 to-sky-700 z-40 shadow-xl flex items-center px-6 sm:px-8 md:px-16 lg:px-24 border-b-4 border-[#fbbf24]">
  </div>

  <div 
    class="relative w-full min-h-[75vh] sm:min-h-[80vh] md:min-h-[85vh] lg:min-h-[90vh] flex flex-col justify-center pt-32 sm:pt-40 md:pt-48 lg:pt-56 xl:pt-64 pb-12 sm:pb-16 bg-cover bg-center"
    style="background-image: url('/images/hero.webp');"
  >
    <!-- Overlay -->
    <div class="absolute inset-0 bg-sky-900/40 mix-blend-multiply"></div>
    <div class="absolute inset-0 bg-linear-to-r from-sky-900/80 via-sky-600/30 to-transparent"></div>

    <!-- Hanging Logos -->
    <div class="absolute top-8 left-6 sm:left-8 md:left-16 lg:left-24 flex gap-4 sm:gap-6 z-50">
      <!-- MPK Logo -->
      <div class="relative group">
        <div class="w-14 h-20 sm:w-16 sm:h-24 md:w-20 md:h-28 lg:w-24 lg:h-36 xl:w-28 xl:h-40 bg-white flex flex-col items-center justify-center p-2 sm:p-3 md:p-4 relative shadow-2xl" style="clip-path: polygon(0 0, 100% 0, 100% 85%, 50% 100%, 0 85%);">
          <img src="/images/logo-mpk.webp" alt="Logo MPK" class="w-full h-auto object-contain no-drag" />
        </div>
      </div>
      
      <!-- SMK Logo -->
      <div class="relative group">
        <div class="w-14 h-20 sm:w-16 sm:h-24 md:w-20 md:h-28 lg:w-24 lg:h-36 xl:w-28 xl:h-40 bg-white flex flex-col items-center justify-center p-2 sm:p-3 md:p-4 relative shadow-2xl" style="clip-path: polygon(0 0, 100% 0, 100% 85%, 50% 100%, 0 85%);">
          <img src="/images/logo-smk.webp" alt="Logo SMK" class="w-full h-auto object-contain no-drag" />
        </div>
      </div>
    </div>

    <!-- Main Content -->
    <div class="relative z-10 w-full px-6 sm:px-8 md:px-16 lg:px-24">
      <div class="max-w-4xl">
        <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-black text-white leading-[0.9] mb-4 sm:mb-6 md:mb-8 tracking-tighter uppercase" style="text-shadow: 4px 4px 15px rgba(0,0,0,0.3);">
          LAYANAN<br/>
          <span class="text-[#fbbf24]">ASPIRASI</span> SISWA
        </h1>
        
        <p class="text-base sm:text-lg md:text-xl lg:text-xl text-white/90 max-w-2xl mb-6 sm:mb-8 md:mb-12 leading-relaxed font-medium border-l-4 border-[#fbbf24] pl-4 sm:pl-6">
          Sampaikan aspirasi, kritik, dan saran untuk kemajuan SMK N 1 Kandeman yang lebih transparan dan inovatif. Suaramu adalah prioritas kami.
        </p>
        
        <div class="flex flex-wrap items-center gap-4 sm:gap-6">
          <Button variant="secondary" class="h-11 sm:h-12 px-6 sm:px-10 text-sm sm:text-base font-bold shadow-lg bg-[#ffcc00] text-[#8b0000] hover:bg-[#e6b800]">
            Sampaikan Aspirasi
            <SendHorizontal class="w-5 h-5 ml-2" />
          </Button>
          <Button variant="outline" class="h-11 sm:h-12 px-6 sm:px-10 text-sm sm:text-base border-2 border-white/30 bg-white/10 text-white hover:bg-white/20 hover:text-white backdrop-blur-md font-bold shadow-lg">
            Selengkapnya
          </Button>
        </div>
      </div>
    </div>
  </div>
</section>
